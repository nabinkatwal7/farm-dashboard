datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Farm {
  id                 String               @id @default(uuid())
  name               String
  location           String?
  lat                Float?
  lng                Float?
  acreage            Float?
  users              User[]
  fields             CropField[]
  animals            Animal[]
  breedingRecords    BreedingRecord[]
  stockItems         StockItem[]
  batches            BatchRecord[]
  products           Product[]
  sales              SaleRecord[]
  machines           Machine[]
  tasks              Task[]
  expenses           ExpenseRecord[]
  prescriptionMaps   PrescriptionMap[]
  seedIntegrations   SeedIntegration[]
  weatherStations    WeatherStation[]
  cropModels         CropModel[]
  gddRecords         GDDRecord[]
  growthStageForecasts GrowthStageForecast[]
  soilZones          SoilZone[]
  soilMoistureRecords SoilMoistureRecord[]
  waterTableReadings WaterTableReading[]
  irrigationEvents   IrrigationEvent[]
  seedLots           SeedLot[]
  germinationTests   GerminationTest[]
  consignments       Consignment[]
  droneFlights       DroneFlight[]
  orthomosaicMaps    OrthomosaicMap[]
  scoutingObservations ScoutingObservation[]
  drydownBatches     DrydownBatch[]
  livestockIntegrations LivestockIntegration[]
  livestockSyncRecords  LivestockSyncRecord[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  passwordHash   String
  name           String
  role           String             @default("FIELD_WORKER")
  isActive       Boolean            @default(true)
  farmId         String
  farm           Farm               @relation(fields: [farmId], references: [id], onDelete: Cascade)
  sessions       Session[]
  assignedTasks  Task[]             @relation("TaskAssignee")
  inputLogs      InputLog[]         @relation("InputOperator")
  stockMoves     StockAdjustment[]  @relation("StockOperator")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model CropField {
  id                  String                @id @default(uuid())
  farmId              String
  farm                Farm                  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name                String
  acres               Float
  currentCrop         String
  status              String
  sowDate             String
  harvestDate         String?
  lat                 Float
  lng                 Float
  boundary            String                @default("[]")
  rotation            FieldRotation[]
  inputs              InputLog[]
  yields              YieldRecord[]
  prescriptionMaps    PrescriptionMap[]
  gddRecords          GDDRecord[]
  growthStageForecasts GrowthStageForecast[]
  soilZones           SoilZone[]
  waterTableReadings  WaterTableReading[]
  irrigationEvents    IrrigationEvent[]
  consignments        Consignment[]
  droneFlights        DroneFlight[]
  orthomosaicMaps     OrthomosaicMap[]
  scoutingObservations ScoutingObservation[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([farmId, name])
}

model FieldRotation {
  id      String    @id @default(uuid())
  year    Int
  crop    String
  fieldId String
  field   CropField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model InputLog {
  id         String    @id @default(uuid())
  date       String
  fieldId    String
  fieldName  String
  field      CropField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  type       String
  product    String
  quantity   String
  unit       String
  operator   String
  operatorId String?
  operatorUser User?   @relation("InputOperator", fields: [operatorId], references: [id], onDelete: SetNull)
  notes      String?
}

model YieldRecord {
  id        String    @id @default(uuid())
  fieldId   String
  fieldName String
  field     CropField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  crop      String
  year      Int
  projected Float
  actual    Float
  unit      String
}

model Animal {
  id             String          @id @default(uuid())
  farmId         String
  farm           Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  earTag         String
  species        String
  breed          String
  sex            String
  dob            String
  group          String?
  status         String
  notes          String?
  medicalRecords MedicalRecord[]
  weights        WeightRecord[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([farmId, earTag])
}

model MedicalRecord {
  id             String  @id @default(uuid())
  animalId       String
  earTag         String
  animal         Animal  @relation(fields: [animalId], references: [id], onDelete: Cascade)
  date           String
  type           String
  product        String?
  condition      String?
  vetName        String?
  withdrawalDays Int?
  withdrawalEnd  String?
  notes          String?
}

model BreedingRecord {
  id            String @id @default(uuid())
  farmId        String
  farm          Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  damEarTag     String
  sireEarTag    String?
  breedingDate  String
  expectedBirth String
  actualBirth   String?
  offspring     Int?
  status        String
  notes         String?
}

model WeightRecord {
  id       String @id @default(uuid())
  animalId String
  earTag   String
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  date     String
  weightKg Float
  notes    String?
}

model StockItem {
  id             String            @id @default(uuid())
  farmId         String
  farm           Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name           String
  category       String
  subCategory    String
  quantity       Float
  unit           String
  minStock       Float
  location       String
  batchId        String?
  fieldOrigin    String?
  animalOrigin   String?
  updatedAt      String
  adjustments    StockAdjustment[]
}

model StockAdjustment {
  id            String    @id @default(uuid())
  stockItemId   String
  stockItemName String
  stockItem     StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  date          String
  delta         Float
  reason        String
  operator      String
  operatorId    String?
  operatorUser  User?     @relation("StockOperator", fields: [operatorId], references: [id], onDelete: SetNull)
}

model BatchRecord {
  id            String @id @default(uuid())
  farmId        String
  farm          Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  batchCode     String
  product       String
  origin        String
  originType    String
  processedDate String
  quantity      Float
  unit          String
  status        String

  @@unique([farmId, batchCode])
}

model Product {
  id       String     @id @default(uuid())
  farmId   String
  farm     Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name     String
  category String
  price    Float
  cost     Float
  stock    Float
  unit     String
  batchId  String?
  sales    SaleItem[]
}

model SaleRecord {
  id            String     @id @default(uuid())
  farmId        String
  farm          Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  date          String
  channel       String
  total         Float
  paymentMethod String
  items         SaleItem[]
}

model SaleItem {
  id        String     @id @default(uuid())
  saleId    String
  sale      SaleRecord @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  name      String
  qty       Int
  price     Float
}

model Machine {
  id          String @id @default(uuid())
  farmId      String
  farm        Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name        String
  type        String
  make        String
  model       String
  year        Int
  engineHours Float
  lastService String
  nextService Float
  status      String
}

model Task {
  id          String  @id @default(uuid())
  farmId      String
  farm        Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  title       String
  description String
  fieldName   String?
  lat         Float?
  lng         Float?
  assignee    String
  assigneeId  String?
  assigneeUser User?  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  dueDate     String
  status      String
  priority    String
}

model ExpenseRecord {
  id          String  @id @default(uuid())
  farmId      String
  farm        Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  date        String
  category    String
  description String
  amount      Float
  supplier    String?
  fieldName   String?
  invoiceRef  String?
  notes       String?
}

model PrescriptionMap {
  id          String         @id @default(uuid())
  farmId      String
  farm        Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name        String
  fieldId     String
  field       CropField      @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldName   String
  crop        String
  season      String
  targetRate  Float?
  status      String         @default("draft")
  notes       String?
  zones       SeedingZone[]
  exportedAt  String?
  exportFormat String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([farmId, name])
}

model SeedingZone {
  id                String           @id @default(uuid())
  prescriptionMapId String
  prescriptionMap   PrescriptionMap  @relation(fields: [prescriptionMapId], references: [id], onDelete: Cascade)
  name              String
  rate              Float
  areaAcres         Float
  lat               Float
  lng               Float
  color             String           @default("#4ade80")
}

model SeedIntegration {
  id                  String  @id @default(uuid())
  farmId              String
  farm                Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  provider            String
  label               String
  apiEndpoint         String?
  apiKey              String?
  username            String?
  password            String?
  machineId           String?
  machineName         String?
  isActive            Boolean @default(false)
  lastSyncAt          String?
  lastSyncStatus      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([farmId, provider])
}

model WeatherStation {
  id             String          @id @default(uuid())
  farmId         String
  farm           Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  name           String
  provider       String
  apiEndpoint    String?
  apiKey         String?
  lat            Float?
  lng            Float?
  isActive       Boolean         @default(true)
  lastSyncAt     String?
  lastSyncStatus String?
  records        WeatherRecord[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([farmId, name])
}

model WeatherRecord {
  id             String          @id @default(uuid())
  stationId      String
  station        WeatherStation  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  timestamp      String
  temperatureMin Float?
  temperatureMax Float?
  temperature    Float?
  humidity       Float?
  windSpeed      Float?
  windDirection  Float?
  precipitation  Float?
  solarRadiation Float?
  soilTemp       Float?
  soilMoisture   Float?
  createdAt      DateTime        @default(now())

  @@index([stationId, timestamp])
}

model CropModel {
  id                String   @id @default(uuid())
  farmId            String
  farm              Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  crop              String
  baseTemp          Float    @default(0)
  optimalTemp       Float    @default(25)
  maxTemp           Float    @default(35)
  gddToGermination  Float?
  gddToEmergence    Float?
  gddToVegetative   Float?
  gddToFlowering    Float?
  gddToFruiting     Float?
  gddToMaturity     Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([farmId, crop])
}

model GDDRecord {
  id              String    @id @default(uuid())
  farmId          String
  farm            Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldId         String
  field           CropField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  season          Int
  date            String
  dailyGDD        Float
  cumulativeGDD   Float
  method          String    @default("standard")
  createdAt       DateTime  @default(now())

  @@index([fieldId, season, date])
}

model GrowthStageForecast {
  id                 String    @id @default(uuid())
  farmId             String
  farm               Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldId            String
  field              CropField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  crop               String
  season             Int
  stage              String
  forecastDate       String
  confidence         Float     @default(0.8)
  gddRequired        Float
  cumulativeGddAtStage Float
  actualDate         String?
  actualGdd          Float?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([fieldId, season, stage])
}

model SoilZone {
  id        String                @id @default(uuid())
  farmId    String
  farm      Farm                  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldId   String
  field     CropField             @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  name      String
  depthFrom Float
  depthTo   Float
  lat       Float?
  lng       Float?
  soilType  String?
  notes     String?
  records   SoilMoistureRecord[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model SoilMoistureRecord {
  id                    String    @id @default(uuid())
  zoneId                String
  zone                  SoilZone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  farmId                String
  farm                  Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  timestamp             String
  moisturePercent       Float
  temperature           Float?
  electricalConductivity Float?
  createdAt             DateTime  @default(now())

  @@index([zoneId, timestamp])
}

model WaterTableReading {
  id          String    @id @default(uuid())
  farmId      String
  farm        Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldId     String?
  field       CropField? @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  timestamp   String
  depthToWater Float
  wellName    String?
  lat         Float?
  lng         Float?
  notes       String?
  createdAt   DateTime  @default(now())

  @@index([farmId, timestamp])
}

model IrrigationEvent {
  id             String        @id @default(uuid())
  farmId         String
  farm           Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldId        String
  field          CropField     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  date           String
  amountMm       Float
  method         String
  source         String?
  durationHours  Float?
  notes          String?
  createdAt      DateTime      @default(now())

  @@index([fieldId, date])
}

model SeedLot {
  id                  String             @id @default(uuid())
  farmId              String
  farm                Farm               @relation(fields: [farmId], references: [id], onDelete: Cascade)
  crop                String
  variety             String?
  lotNumber           String
  supplier            String?
  purchaseDate        String?
  quantity            Float
  unit                String             @default("kg")
  treatmentType       String             @default("none")
  treatmentProduct    String?
  treatmentDate       String?
  baselineGermination Float?
  notes               String?
  germinationTests    GerminationTest[]
  consignments        Consignment[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([farmId, lotNumber])
}

model GerminationTest {
  id                  String    @id @default(uuid())
  seedLotId           String
  seedLot             SeedLot   @relation(fields: [seedLotId], references: [id], onDelete: Cascade)
  farmId              String
  farm                Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  testDate            String
  seedsTested         Int
  seedsGerminated     Int
  germinationPercent  Float
  testMethod          String    @default("paper")
  notes               String?
  createdAt           DateTime  @default(now())

  @@index([seedLotId, testDate])
}

model Consignment {
  id          String     @id @default(uuid())
  farmId      String
  farm        Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldId     String?
  field       CropField? @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  seedLotId   String?
  seedLot     SeedLot?   @relation(fields: [seedLotId], references: [id], onDelete: SetNull)
  date        String
  quantity    Float
  unit        String     @default("kg")
  destination String?
  sowingDate  String?
  notes       String?
  createdAt   DateTime   @default(now())

  @@index([farmId, date])
}

model DroneFlight {
  id               String       @id @default(uuid())
  farmId           String
  farm             Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldId          String?
  field            CropField?   @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  flightDate       String
  droneType        String?
  altitude         Float?
  groundResolution Float?
  coverageAcres    Float?
  status           String       @default("completed")
  notes            String?
  maps             OrthomosaicMap[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([farmId, flightDate])
}

model OrthomosaicMap {
  id            String              @id @default(uuid())
  farmId        String
  farm          Farm                @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldId       String?
  field         CropField?          @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  flightId      String?
  flight        DroneFlight?        @relation(fields: [flightId], references: [id], onDelete: SetNull)
  name          String
  fileType      String
  filePath      String?
  resolution    Float?
  coverageAcres Float?
  fileSize      Float?
  notes         String?
  observations  ScoutingObservation[]
  createdAt     DateTime            @default(now())

  @@index([farmId, fileType])
}

model ScoutingObservation {
  id              String         @id @default(uuid())
  farmId          String
  farm            Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  fieldId         String?
  field           CropField?     @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  mapId           String?
  map             OrthomosaicMap? @relation(fields: [mapId], references: [id], onDelete: SetNull)
  observationType String
  severity        String         @default("medium")
  lat             Float?
  lng             Float?
  areaAcres       Float?
  notes           String?
  imageUrl        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([farmId, observationType])
}

model DrydownBatch {
  id               String   @id @default(uuid())
  farmId           String
  farm             Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  storageName      String
  grainType        String
  cropYear         Int
  initialMoisture  Float
  initialWeight    Float
  initialUnit      String   @default("lbs")
  currentMoisture  Float
  currentTemperature Float?
  currentHumidity  Float?
  targetMoisture   Float?
  status           String   @default("drying")
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([farmId, status])
}

model LivestockIntegration {
  id             String   @id @default(uuid())
  farmId         String
  farm           Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  provider       String
  label          String
  apiEndpoint    String?
  apiKey         String?
  herdMark       String?
  isActive       Boolean  @default(false)
  lastSyncAt     String?
  lastSyncStatus String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([farmId, provider])
}

model LivestockSyncRecord {
  id             String   @id @default(uuid())
  farmId         String
  farm           Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  eventType      String
  animalId       String?
  animalEarTag   String?
  status         String   @default("pending")
  requestPayload String?
  responseData   String?
  errorMessage   String?
  syncedAt       String?
  createdAt      DateTime @default(now())

  @@index([farmId, eventType])
  @@index([farmId, status])
}
